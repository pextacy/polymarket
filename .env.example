# ── LLM Provider ────────────────────────────────────────────────────────────────
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Per-task model overrides (defaults to LLM_MODEL if unset)
LLM_MODEL=openai/gpt-4o
LLM_MODEL_RANKING=openai/gpt-4o-mini
LLM_MODEL_FORECASTING=openai/gpt-4o
LLM_MODEL_EXTRACTION=openai/gpt-4o-mini

# ── Search ──────────────────────────────────────────────────────────────────────
SEARCH_PROVIDER=searxng
SEARXNG_BASE_URL=http://localhost:8888
SEARXNG_TIMEOUT_SECONDS=15

# ── Browser (Lightpanda CDP) ────────────────────────────────────────────────────
LIGHTPANDA_WS_URL=ws://localhost:9222
LIGHTPANDA_TIMEOUT_SECONDS=30
LIGHTPANDA_MAX_PAGE_BYTES=2097152

# ── Polymarket ──────────────────────────────────────────────────────────────────
GAMMA_BASE_URL=https://gamma-api.polymarket.com
CLOB_BASE_URL=https://clob.polymarket.com
DATA_API_BASE_URL=https://data-api.polymarket.com
POLYMARKET_CHAIN_ID=137

# Live trading (leave blank unless live mode is explicitly needed)
POLYMARKET_PRIVATE_KEY=
POLYMARKET_PROXY_ADDRESS=

# ── Trading Mode ────────────────────────────────────────────────────────────────
TRADING_MODE=paper

# ── Risk Limits ─────────────────────────────────────────────────────────────────
RISK_MAX_NOTIONAL_PER_MARKET=50.0
RISK_MAX_PORTFOLIO_EXPOSURE=500.0
RISK_MAX_CATEGORY_EXPOSURE=150.0
RISK_MAX_DAILY_LOSS=100.0
RISK_MAX_OPEN_POSITIONS=20
RISK_MAX_OPEN_ORDERS=40
RISK_SIGNAL_STALENESS_SECONDS=3600
RISK_EXPIRY_NO_TRADE_HOURS=2
RISK_COOLDOWN_AFTER_LOSSES=3
RISK_COOLDOWN_DURATION_SECONDS=3600

# ── Paper Broker ────────────────────────────────────────────────────────────────
PAPER_INITIAL_CASH=10000.0
PAPER_FILL_SLIPPAGE_BPS=20
LIVE_FILL_SLIPPAGE_BPS=10

# ── Persistence ─────────────────────────────────────────────────────────────────
# Local dev (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./polymarket_trader.db
# Production (Postgres — use with docker-compose postgres service):
# DATABASE_URL=postgresql+asyncpg://trader:changeme@localhost:5432/polymarket_trader

# ── Docker / Infrastructure ──────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme
DAYTONA_API_KEY=

# ── Scan Cycle ──────────────────────────────────────────────────────────────────
SCAN_INTERVAL_SECONDS=900
SCAN_MARKET_LIMIT=100
SCAN_MIN_LIQUIDITY_USDC=500.0
SCAN_MIN_VOLUME_24H_USDC=1000.0
SCAN_MAX_RESEARCH_SOURCES=5
SCAN_MIN_EDGE_BPS=200

# ── Observability ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/trader.log
